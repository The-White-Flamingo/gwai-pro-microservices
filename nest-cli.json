      }
    },
    "waitlist-service": {
      "type": "application",
      "root": "apps/waitlist-service",
      "entryFile": "main",
      "sourceRoot": "apps/waitlist-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/waitlist-service/tsconfig.app.json"
      }
    },
    "blog-service": {
      "type": "application",
      "root": "apps/blog-service",
      "entryFile": "main",
