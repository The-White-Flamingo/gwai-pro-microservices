    "chat-service": {
      "type": "application",
      "root": "apps/chat-service",
      "entryFile": "main",
      "sourceRoot": "apps/chat-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/chat-service/tsconfig.app.json"
      }
    },
    "posts-service": {
      "type": "application",
      "root": "apps/posts-service",
      "entryFile": "main",
      "sourceRoot": "apps/posts-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/posts-service/tsconfig.app.json"
      }
    },
    "posts": {
      "type": "library",
      "root": "libs/posts",
      "entryFile": "index",
