        "tsConfigPath": "libs/payments/tsconfig.lib.json"
      }
    },
    "bookings": {
      "type": "library",
      "root": "libs/bookings",
      "entryFile": "index",
      "sourceRoot": "libs/bookings/src",
      "compilerOptions": {
        "tsConfigPath": "libs/bookings/tsconfig.lib.json"
      }
    },
    "iam": {
      "type": "library",
      "root": "libs/iam",
      "entryFile": "index",
      "sourceRoot": "libs/iam/src",
      "compilerOptions": {
        "tsConfigPath": "libs/iam/tsconfig.lib.json"
      }
